{
  "expo": {
    "name": "GoPrep",
    "slug": "goprep-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goprep.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.goprep.mobile",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "goprep",
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#16a34a"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cd9feed7-6bc4-414f-80a7-a080b848f3de"
      }
    }
  }
}
